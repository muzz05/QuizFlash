<Page x:Class="QuizFlash.StudentClassroomPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:QuizFlash"
      xmlns:Icons ="http://metro.mahapps.com/winfx/xaml/iconpacks"              
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="880"
      Title="TeacherClassroomPage">

    <Border CornerRadius="20" Margin="15">
        <Grid>

            <Grid x:Name="loadingOverlay" Background="Transparent" Visibility="Collapsed" Height="450" Width="800">
                <local:Loader HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <Grid x:Name="StudentClassroomGrid">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden" PanningMode="VerticalOnly">
            <WrapPanel x:Name="WrapPanelClassroom" Width="880">
                
            </WrapPanel>
        </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Page>
