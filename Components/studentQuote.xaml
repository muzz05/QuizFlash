<UserControl x:Class="QuizFlash.studentQuote"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuizFlash"
             mc:Ignorable="d" 
             d:DesignHeight="90" d:DesignWidth="350">
    <Border x:Name="cardBorder" CornerRadius="10" Background="#272537" BorderThickness="0" BorderBrush="Transparent"  Margin="0">
        <Border.Effect>
            <DropShadowEffect Color="#c3c4cf" BlurRadius="10" ShadowDepth="3" Opacity="0.3" />
        </Border.Effect>
        <Grid Height="90" Cursor="Hand" Width="350" Margin="0" >
            <TextBlock x:Name="quote" FontSize="14" FontWeight="SemiBold"  Margin="10" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#ffefba" Offset="0.1" />
                        <GradientStop Color="#ffffff" Offset="0.8" />
                    </LinearGradientBrush>
                </TextBlock.Foreground>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>



