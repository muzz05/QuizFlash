<UserControl x:Class="QuizFlash.QuizControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Icons ="http://metro.mahapps.com/winfx/xaml/iconpacks"              
             xmlns:local="clr-namespace:QuizFlash"
             mc:Ignorable="d" 
             d:DesignHeight="240" d:DesignWidth="190"
             Background="Transparent">
    <Grid>
        <Border BorderThickness="0" x:Name="border_of_flashcard" Background="White" CornerRadius="20" Height="240" Width="200" HorizontalAlignment="Center" Padding="0" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="7.5*" />
                    <RowDefinition Height="2.*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="20,20,0,0" Margin="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00BFFF" Offset="0.0" />
                            <GradientStop Color="#6A1B9A" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Margin="15,10,15,0" VerticalAlignment="Top" Height="230">
                        <TextBlock Margin="0,10,0,0" x:Name="QuizName" Foreground="#fafafa" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" Text="Fundamentals of OOPs"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,5,0,0"  Foreground="#fafafa" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Text="Marks:"/>
                            <TextBlock Margin="5,5,0,0" x:Name="QuizMarks" Foreground="#fafafa" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Text="5"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,5,0,0"  Foreground="#fafafa" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Text="Questions:"/>
                            <TextBlock Margin="5,5,0,0" x:Name="QuesCount" Foreground="#fafafa" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Text="10"/>
                        </StackPanel>
                        

                        <StackPanel Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Center" >
                            <!--<TextBlock Margin="0,5,0,0" FontSize="10" FontWeight="Normal" TextWrapping="Wrap" Text="Starts:" Foreground="#fafafa" />-->
                            <TextBlock Margin="0,5,0,0" x:Name="ValidUntil" FontSize="9" FontWeight="SemiBold" TextWrapping="Wrap" Text="5 Aug 2024 5PM" Foreground="#fafafa" />
                        </StackPanel>
                        <Border Background="#305762" CornerRadius="8" HorizontalAlignment="Left" Margin="0,8,0,0">
                            <TextBlock x:Name="DurationBadge" FontSize="9" FontWeight="SemiBold" Foreground="#fafafa" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8, 2">15 Minutes</TextBlock>
                        </Border>

                        <Border CornerRadius="8"  Margin="0,6,0,0" Background="#008080" x:Name="AttemptedBadge" MaxWidth="62" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <TextBlock x:Name="textBlock" Foreground="#fafafa" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Margin="6,3">Attempted</TextBlock>
                        </Border>
                    </StackPanel>
                </Border>


                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Stretch" Width="Auto">
                    
				<Border CornerRadius="10" Grid.Row="1"  HorizontalAlignment="Stretch" Margin="10,0,15,0">
                        <Button Grid.Row="1" VerticalAlignment="Center" Click="result_page_redirect" HorizontalAlignment="Right" Margin="0,0,0,0" Foreground="#fafafa" Height="28" Width="78" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="10" BorderThickness="0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#00BFFF" Offset="0.0" />
                                                <GradientStop Color="#6A1B9A" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="Result" FontSize="16" Margin="0,0,5,0"/>
                                            <Icons:PackIconFontAwesome  Kind="PollSolid" Foreground="#fafafa" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Border>

					<Border CornerRadius="10" HorizontalAlignment="Stretch" Margin="0,0,15,0">
						<Button Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Right" Click="quizRedirect" x:Name="quizStartButton" Foreground="#fafafa" Height="28" Width="70" Cursor="Hand">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border CornerRadius="10" BorderThickness="0">
										<Border.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
												<GradientStop Color="#00BFFF" Offset="0.0" />
												<GradientStop Color="#6A1B9A" Offset="1.0" />
											</LinearGradientBrush>
										</Border.Background>
										<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
											<!-- Add your icon here (e.g., an image or font icon) -->
											<TextBlock Text="Start" FontSize="16" Margin="0,0,5,0"/>
											<Icons:PackIconMaterial  Kind="PlayCircle" Foreground="#fafafa" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,0,0"/>
										</StackPanel>
									</Border>
								</ControlTemplate>
							</Button.Template>
						</Button>
					</Border>

					<Border CornerRadius="10">
						<Button Grid.Row="1" VerticalAlignment="Center" Click="DeleteButton_Click" x:Name="quizDeleteButton" Foreground="#fafafa" Height="28" Width="80" Cursor="Hand">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border CornerRadius="10" BorderThickness="0">
										<Border.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
												<GradientStop Color="#00BFFF" Offset="0.0" />
												<GradientStop Color="#6A1B9A" Offset="1.0" />
											</LinearGradientBrush>
										</Border.Background>
										<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
											<!-- Add your icon here (e.g., an image or font icon) -->
											<TextBlock Text="Delete" FontSize="16" Margin="0,0,5,0"/>
											<Icons:PackIconMaterial  Kind="Delete" Foreground="#fafafa" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,0,0"/>
										</StackPanel>
									</Border>
								</ControlTemplate>
							</Button.Template>
						</Button>
					</Border>
				
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
