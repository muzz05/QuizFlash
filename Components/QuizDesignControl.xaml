<UserControl x:Class="QuizFlash.QuizDesignControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuizFlash"
             mc:Ignorable="d" 
             d:DesignHeight="380" d:DesignWidth="800">
    <Border Background="Transparent" CornerRadius="20" Margin="0,20,0,0">
        <StackPanel>
        <!--<TextBlock Text="Enter the question" FontSize="18" Style="{StaticResource NormalText}" Margin="5" HorizontalAlignment="Center" />-->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="#c3c4cf" CornerRadius="100" HorizontalAlignment="Center" Height="25" Width="25" Grid.Column="0" Padding="5" VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock x:Name="ques_Number" FontSize="13" FontWeight="Bold" Foreground="#4a4a4e" HorizontalAlignment="Center" VerticalAlignment="Center" Height="20">1</TextBlock>
                </Border>
                <TextBox x:Name="questionTextBox" Style="{StaticResource filterTextBox}" Margin="0" Width="500"/>
            </StackPanel>
        <!--<TextBlock Text="Enter the options" FontSize="18" Style="{StaticResource NormalText}" HorizontalAlignment="Center" Margin="5"/>-->

        <StackPanel Width="400" Margin="0,20,0,10" Orientation="Horizontal">
            <TextBlock Text="Option A:" Style="{StaticResource NormalText}" Margin="10 0" VerticalAlignment="Center" Height="20"/>
            <TextBox x:Name="optionATextBox" Style="{StaticResource filterTextBox}" Margin="0 0" Width="300" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Width="400" Margin="0 10" Orientation="Horizontal">
                <TextBlock Text="Option B:" Style="{StaticResource NormalText}" Margin="10 0" VerticalAlignment="Center" Height="20"/>
            <TextBox x:Name="optionBTextBox" Style="{StaticResource filterTextBox}" Margin="0 0" Width="300"/>
        </StackPanel>
        <StackPanel Width="400" Margin="0 10" Orientation="Horizontal">
                <TextBlock Text="Option C:" Style="{StaticResource NormalText}" Margin="10 0" VerticalAlignment="Center" Height="20"/>
            <TextBox x:Name="optionCTextBox" Style="{StaticResource filterTextBox}" Margin="0 0" Width="300"/>
        </StackPanel>
        <StackPanel Width="400" Margin="0 10" Orientation="Horizontal">
                <TextBlock Text="Option D:" Style="{StaticResource NormalText}" Margin="10 0" VerticalAlignment="Center" Height="20"/>
            <TextBox x:Name="optionDTextBox" Style="{StaticResource filterTextBox}" Margin="0 0" Width="300"/>
        </StackPanel>
        <!--<TextBlock Text="Select the correct option" FontSize="18" Style="{StaticResource NormalText}"  HorizontalAlignment="Center" Margin="5"/>-->
        <StackPanel Width="450" Orientation="Horizontal" Margin="0 10" Grid.Row="10">
                <RadioButton Content="Option A" x:Name="optionARadioButton" Style="{StaticResource NavigationButtons}" Checked="optionAcheck"  Width="100"/>
                <RadioButton Content="Option B" x:Name="optionBRadioButton" Style="{StaticResource NavigationButtons}" Checked="optionBcheck" Width="100"/>
                <RadioButton Content="Option C" x:Name="optionCRadioButton" Style="{StaticResource NavigationButtons}" Checked="optionCcheck" Width="100"/>
                <RadioButton Content="Option D" x:Name="optionDRadioButton" Style="{StaticResource NavigationButtons}" Checked="optionDcheck" Width="100"/>
        </StackPanel>
            <Button Content="Delete" Style="{StaticResource MessageBoxButtons}" Width="80" Margin="5" Click="deleteQuestion" HorizontalAlignment="Center" FontSize="14"/>
        </StackPanel>
    </Border>
</UserControl>
